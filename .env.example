# ── Database ───────────────────────────────────────────────────────────────────
# Development (SQLite — default, no setup required):
# DATABASE_URL=sqlite:///./barber.db
#
# Production (PostgreSQL on the same EC2 instance):
DATABASE_URL='postgresql://noobpingui:Trabajar1234@localhost:5432/barber_db'


# ── App ────────────────────────────────────────────────────────────────────────
# Set to false in production. Controls API docs (/docs) and debug error pages.
DEBUG=false

# ── Email notifications ─────────────────────────────────────────────────────────
# EMAIL_PROVIDER: "resend" (default) or "ses"
EMAIL_PROVIDER='resend'
EMAIL_FROM='noreply@booking.betofallas.dev'

# Resend — required when EMAIL_PROVIDER=resend
RESEND_API_KEY=''

# Amazon SES — required when EMAIL_PROVIDER=ses
# Leave AWS_ACCESS_KEY_ID empty to use the EC2 instance's IAM role instead.
AWS_ACCESS_KEY_ID=''
AWS_SECRET_ACCESS_KEY=''
AWS_REGION='us-east-1'


# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY='change-me-to-a-long-random-string'

# ── Business rules ─────────────────────────────────────────────────────────────
# Minimum hours before appointment start that a customer can still cancel.
CANCELLATION_WINDOW_HOURS=1
