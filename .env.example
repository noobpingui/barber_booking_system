# ── Database ───────────────────────────────────────────────────────────────────
# Development (SQLite — default, no setup required):
# DATABASE_URL=sqlite:///./barber.db
#
# Production (PostgreSQL on the same EC2 instance):
DATABASE_URL='postgresql://noobpingui:Trabajar1234@localhost:5432/barber_db'


# ── App ────────────────────────────────────────────────────────────────────────
# Set to false in production. Controls API docs (/docs) and debug error pages.
DEBUG=false

# ── Business rules ─────────────────────────────────────────────────────────────
# Minimum hours before appointment start that a customer can still cancel.
CANCELLATION_WINDOW_HOURS=2
